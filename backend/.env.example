# --- Database (Neon) ---
# Connection string fornita dalla dashboard Neon. Deve usare il driver asyncpg.
# Esempio: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:pass@host/db?ssl=require

# --- Redis (Upstash) ---
# Upstash fornisce sia REDIS_URL (per redis-py) sia un REST endpoint.
# Esempio: rediss://default:pass@host:6379
REDIS_URL=rediss://default:pass@host:6379

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Embeddings (Voyage AI) ---
VOYAGE_API_KEY=

# --- Data sources ---
POLYGON_API_KEY=
MARKETAUX_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=

# --- Auth (Resend per magic link) ---
RESEND_API_KEY=
AUTH_SECRET=change-me-to-a-long-random-string
ALLOWED_EMAIL=

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
